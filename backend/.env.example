# Generate these with: python -c "from app.core.security import generate_keys; print(generate_keys())"
JWT_SECRET_KEY=your-32-byte-hex-secret
FERNET_KEY=your-fernet-base64-key

# Supabase (get from supabase.com project settings)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=csv-uploads

# LLM — set LLM_PROVIDER to "openai" or "anthropic"
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
